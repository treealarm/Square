{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build: solution",
      "detail": "dotnet build всего решения (Debug)",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/LeafletAlarms.sln",
        "-c",
        "Debug",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build: backend (LeafletAlarms)",
      "detail": "Сборка главного web/grpc-приложения",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/LeafletAlarms/LeafletAlarms.csproj",
        "-c",
        "Debug",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build: integrationhost (IntegrationHost)",
      "detail": "Приёмный gRPC-слой интеграции (продьюсеры пушат сюда)",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/IntegrationHost/IntegrationHost.csproj",
        "-c",
        "Debug",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build: aasubservice (AASubService)",
      "detail": "Интеграция ONVIF-камер",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/AASubService/AASubService.csproj",
        "-c",
        "Debug",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build: grpctracksclient (GrpcTracksClient)",
      "detail": "Симулятор: двигает машинки (figures/tracks)",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/GrpcTracksClient/GrpcTracksClient.csproj",
        "-c",
        "Debug",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build: blinkservice (BlinkService)",
      "detail": "Подписчик алармов/интеграций",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/BlinkService/BlinkService.csproj",
        "-c",
        "Debug",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "clean: solution",
      "type": "process",
      "command": "dotnet",
      "args": ["clean", "${workspaceFolder}/LeafletAlarms.sln"],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "client: npm install",
      "detail": "Установка зависимостей React-клиента",
      "type": "process",
      "command": "npm",
      "args": ["install"],
      "options": { "cwd": "${workspaceFolder}/tree_alarm.client" },
      "problemMatcher": []
    },
    {
      "label": "client: build",
      "detail": "Production-сборка клиента (vite build)",
      "type": "process",
      "command": "npm",
      "args": ["run", "build"],
      "options": { "cwd": "${workspaceFolder}/tree_alarm.client" },
      "problemMatcher": []
    },
    {
      "label": "client: dev (vite)",
      "detail": "Dev-сервер Vite на http://localhost:8002 (фоновая задача)",
      "type": "process",
      "command": "npm",
      "args": ["run", "dev"],
      "options": { "cwd": "${workspaceFolder}/tree_alarm.client" },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*VITE.*",
          "endsPattern": ".*(Local:|ready in).*"
        }
      }
    },
   {
      "label": "dapr: run all apps",
      "detail": "Запуск всех 5 .NET-сервисов (leafletalarms, integrationhost, grpctracksclient, aasubservice, blinkservice) с dapr-сайдкарами (dapr.yaml)",
      "type": "process",
      "command": "dapr",
      "args": ["run", "-f", "${workspaceFolder}/dapr.yaml"],
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "daprd: leafletalarms (F5)",
      "detail": "Dapr-сайдкар для бэкенда (для отладки по F5). Использует self-hosted placement/scheduler/redis от `dapr init`.",
      "type": "shell",
      "command": "${userHome}/.dapr/bin/daprd",
      "args": [
        "--app-id", "leafletalarms",
        // leafletalarms больше не хостит gRPC — это чистый HTTP-фронт (REST/WebSocket/SPA)
        // и Dapr-клиент. app-port указывает на реально слушаемый http-порт (HTTP_PORT=8085 в launch.json).
        "--app-port", "8085",
        "--app-protocol", "http",
        "--dapr-http-port", "3500",
        "--dapr-grpc-port", "50001",
        "--metrics-port", "9090",
        "--placement-host-address", "localhost:50005",
        "--scheduler-host-address", "localhost:50006",
        "--resources-path", "${workspaceFolder}/init_files/dapr_components_local",
        "--log-level", "info"
      ],
      "isBackground": true,
      // endsPattern НЕ 'Status: Running': с --app-port daprd блокируется в ожидании
      // приложения, которое отладчик запустит уже ПОСЛЕ prep. Берём момент готовности
      // самого сайдкара, иначе prep зависнет навсегда (дедлок).
      "problemMatcher": {
        "pattern": [
          { "regexp": ".", "file": 1, "location": 2, "message": 3 }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "This will block until the app is listening on that port"
        }
      }
    },
    {
      "label": "daprd: stop (F5)",
      "detail": "Останавливает Dapr-сайдкар после завершения отладки.",
      "type": "shell",
      "command": "pkill -f 'app-id leafletalarms' || true",
      "problemMatcher": []
    },
    {
      "label": "prep: F5 backend",
      "detail": "preLaunchTask для F5: инфра -> сборка бэкенда -> запуск Dapr-сайдкара.",
      "dependsOrder": "sequence",
      "dependsOn": [
        "build: backend (LeafletAlarms)",
        "daprd: leafletalarms (F5)"
      ],
      "problemMatcher": []
    },
    {
      "label": "daprd: integrationhost (F5)",
      "detail": "Dapr-сайдкар для приёмного gRPC-слоя интеграции (отладка по F5). Свои dapr-порты (3501/50011), чтобы не конфликтовать с leafletalarms.",
      "type": "shell",
      "command": "${userHome}/.dapr/bin/daprd",
      "args": [
        "--app-id", "integrationhost",
        "--app-port", "5000",
        "--app-protocol", "grpc",
        "--dapr-http-port", "3501",
        "--dapr-grpc-port", "50011",
        "--metrics-port", "9091",
        "--placement-host-address", "localhost:50005",
        "--scheduler-host-address", "localhost:50006",
        "--resources-path", "${workspaceFolder}/init_files/dapr_components_local",
        "--log-level", "info"
      ],
      "isBackground": true,
      // см. комментарий в daprd: leafletalarms (F5): с --app-port daprd блокируется
      // в ожидании приложения, ловим момент готовности самого сайдкара.
      "problemMatcher": {
        "pattern": [
          { "regexp": ".", "file": 1, "location": 2, "message": 3 }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "This will block until the app is listening on that port"
        }
      }
    },
    {
      "label": "daprd: stop integrationhost (F5)",
      "detail": "Останавливает Dapr-сайдкар integrationhost после завершения отладки.",
      "type": "shell",
      "command": "pkill -f 'app-id integrationhost' || true",
      "problemMatcher": []
    },
    {
      "label": "prep: F5 integrationhost",
      "detail": "preLaunchTask для F5: инфра -> сборка integrationhost -> запуск его Dapr-сайдкара.",
      "dependsOrder": "sequence",
      "dependsOn": [
        "build: integrationhost (IntegrationHost)",
        "daprd: integrationhost (F5)"
      ],
      "problemMatcher": []
    },
    {
      "label": "daprd: grpctracksclient (F5)",
      "detail": "Dapr-сайдкар симулятора машинок. dapr-порты 3502/50021.",
      "type": "shell",
      "command": "${userHome}/.dapr/bin/daprd",
      "args": [
        "--app-id", "grpctracksclient",
        "--app-port", "20007",
        "--app-protocol", "grpc",
        "--dapr-http-port", "3502",
        "--dapr-grpc-port", "50021",
        "--metrics-port", "9092",
        "--placement-host-address", "localhost:50005",
        "--scheduler-host-address", "localhost:50006",
        "--resources-path", "${workspaceFolder}/init_files/dapr_components_local",
        "--log-level", "info"
      ],
      "isBackground": true,
      "problemMatcher": {
        "pattern": [ { "regexp": ".", "file": 1, "location": 2, "message": 3 } ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "This will block until the app is listening on that port"
        }
      }
    },
    {
      "label": "daprd: stop grpctracksclient (F5)",
      "type": "shell",
      "command": "pkill -f 'app-id grpctracksclient' || true",
      "problemMatcher": []
    },
    {
      "label": "prep: F5 grpctracksclient",
      "dependsOrder": "sequence",
      "dependsOn": [
        "build: grpctracksclient (GrpcTracksClient)",
        "daprd: grpctracksclient (F5)"
      ],
      "problemMatcher": []
    },
    {
      "label": "daprd: aasubservice (F5)",
      "detail": "Dapr-сайдкар интеграции камер. dapr-порты 3503/50031.",
      "type": "shell",
      "command": "${userHome}/.dapr/bin/daprd",
      "args": [
        "--app-id", "aasubservice",
        "--app-port", "20008",
        "--app-protocol", "grpc",
        "--dapr-http-port", "3503",
        "--dapr-grpc-port", "50031",
        "--metrics-port", "9093",
        "--placement-host-address", "localhost:50005",
        "--scheduler-host-address", "localhost:50006",
        "--resources-path", "${workspaceFolder}/init_files/dapr_components_local",
        "--log-level", "info"
      ],
      "isBackground": true,
      "problemMatcher": {
        "pattern": [ { "regexp": ".", "file": 1, "location": 2, "message": 3 } ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "This will block until the app is listening on that port"
        }
      }
    },
    {
      "label": "daprd: stop aasubservice (F5)",
      "type": "shell",
      "command": "pkill -f 'app-id aasubservice' || true",
      "problemMatcher": []
    },
    {
      "label": "prep: F5 aasubservice",
      "dependsOrder": "sequence",
      "dependsOn": [
        "build: aasubservice (AASubService)",
        "daprd: aasubservice (F5)"
      ],
      "problemMatcher": []
    },
    {
      "label": "daprd: blinkservice (F5)",
      "detail": "Dapr-сайдкар подписчика алармов (использует акторы + БД). dapr-порты 3504/50041.",
      "type": "shell",
      "command": "${userHome}/.dapr/bin/daprd",
      "args": [
        "--app-id", "blinkservice",
        "--app-port", "20009",
        "--app-protocol", "http",
        "--dapr-http-port", "3504",
        "--dapr-grpc-port", "50041",
        "--metrics-port", "9094",
        "--placement-host-address", "localhost:50005",
        "--scheduler-host-address", "localhost:50006",
        "--resources-path", "${workspaceFolder}/init_files/dapr_components_local",
        "--log-level", "info"
      ],
      "isBackground": true,
      "problemMatcher": {
        "pattern": [ { "regexp": ".", "file": 1, "location": 2, "message": 3 } ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "This will block until the app is listening on that port"
        }
      }
    },
    {
      "label": "daprd: stop blinkservice (F5)",
      "type": "shell",
      "command": "pkill -f 'app-id blinkservice' || true",
      "problemMatcher": []
    },
    {
      "label": "prep: F5 blinkservice",
      "dependsOrder": "sequence",
      "dependsOn": [
        "build: blinkservice (BlinkService)",
        "daprd: blinkservice (F5)"
      ],
      "problemMatcher": []
    }
  ]
}
