{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: LeafletAlarms (coreclr)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "prep: F5 backend",
      "postDebugTask": "daprd: stop (F5)",
      "program": "${workspaceFolder}/LeafletAlarms/bin/Debug/net8.0/LeafletAlarms.dll",
      "args": [],
      "cwd": "${workspaceFolder}/LeafletAlarms",
      "stopAtEntry": false,
      "console": "integratedTerminal",
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "http://localhost:8085/swagger"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_HOSTINGSTARTUPASSEMBLIES": "Microsoft.AspNetCore.SpaProxy",
        "HTTP_PORT": "8085",
        "APP_PORT": "5000",
        "VALHALLA_URL": "http://localhost:8012",
        "PUBSUB_NAME": "orderpubsub",
        "DAPR_HTTP_PORT": "3500",
        "DAPR_GRPC_PORT": "50001",
        "MapDatabase__PgHost": "localhost",
        "MapDatabase__PgPort": "5433",
        "RoutingSettings__root_folder_win": "${workspaceFolder}/leaflet_data",
        "POSTGRES_USER": "keycloak",
        "POSTGRES_PASSWORD": "password",
        "DB_REALM_NAME": "myrealm",
        "KEYCLOAK_URL": "http://localhost:8080",
        "KEYCLOAK_ADMIN_USER": "admin",
        "KEYCLOAK_ADMIN_PASSWORD": "admin",
        "KEYCLOAK_CLIENT_ID": "admin-cli"
      }
    },
    {
      "name": "Client: Vite dev (Chrome)",
      "type": "chrome",
      "request": "launch",
      "preLaunchTask": "client: dev (vite)",
      "url": "http://localhost:8002",
      "webRoot": "${workspaceFolder}/tree_alarm.client/src"
    }
  ],
  "compounds": [
    {
      "name": "Full: Backend + Client",
      "configurations": [
        "Backend: LeafletAlarms (coreclr)",
        "Client: Vite dev (Chrome)"
      ],
      "stopAll": true
    }
  ]
}
