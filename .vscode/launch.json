{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: LeafletAlarms (coreclr)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "prep: F5 backend",
      "postDebugTask": "daprd: stop (F5)",
      "program": "${workspaceFolder}/LeafletAlarms/bin/Debug/net8.0/LeafletAlarms.dll",
      "args": [],
      "cwd": "${workspaceFolder}/LeafletAlarms",
      "stopAtEntry": false,
      "console": "integratedTerminal",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_HOSTINGSTARTUPASSEMBLIES": "Microsoft.AspNetCore.SpaProxy",
        "HTTP_PORT": "8085",
        "APP_PORT": "5000",
        "VALHALLA_URL": "http://localhost:8012",
        "PUBSUB_NAME": "orderpubsub",
        "DAPR_HTTP_PORT": "3500",
        "DAPR_GRPC_PORT": "50001",
        "MapDatabase__PgHost": "localhost",
        "MapDatabase__PgPort": "5432",
        "RoutingSettings__root_folder_win": "${workspaceFolder}/leaflet_data",
        "POSTGRES_USER": "keycloak",
        "POSTGRES_PASSWORD": "password",
        "DB_REALM_NAME": "myrealm",
        "KEYCLOAK_URL": "http://localhost:8080",
        "KEYCLOAK_ADMIN_USER": "admin",
        "KEYCLOAK_ADMIN_PASSWORD": "admin",
        "KEYCLOAK_CLIENT_ID": "admin-cli"
      }
    },
    {
      "name": "IntegrationHost (coreclr)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "prep: F5 integrationhost",
      "postDebugTask": "daprd: stop integrationhost (F5)",
      "program": "${workspaceFolder}/IntegrationHost/bin/Debug/net8.0/IntegrationHost.dll",
      "args": [],
      "cwd": "${workspaceFolder}/IntegrationHost",
      "stopAtEntry": false,
      "console": "integratedTerminal",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "APP_PORT": "5000",
        "PUBSUB_NAME": "orderpubsub",
        "DAPR_HTTP_PORT": "3501",
        "DAPR_GRPC_PORT": "50011",
        "MapDatabase__PgHost": "localhost",
        "MapDatabase__PgPort": "5432",
        "RoutingSettings__root_folder_win": "${workspaceFolder}/leaflet_data",
        "POSTGRES_USER": "keycloak",
        "POSTGRES_PASSWORD": "password",
        "DB_REALM_NAME": "myrealm"
      }
    },
    {
      "name": "GrpcTracksClient (coreclr)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "prep: F5 grpctracksclient",
      "postDebugTask": "daprd: stop grpctracksclient (F5)",
      "program": "${workspaceFolder}/GrpcTracksClient/bin/Debug/net8.0/GrpcTracksClient.dll",
      "args": [],
      "cwd": "${workspaceFolder}/GrpcTracksClient",
      "stopAtEntry": false,
      "console": "integratedTerminal",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "APP_PORT": "20007",
        "APP_ID": "grpctracksclient",
        "LEAFLETALARM_APP_ID": "integrationhost",
        "DAPR_HTTP_PORT": "3502",
        "DAPR_GRPC_PORT": "50021",
        "PUBSUB_NAME": "orderpubsub",
        "VALHALLA_URL": "http://localhost:8012"
      }
    },
    {
      "name": "AASubService (coreclr)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "prep: F5 aasubservice",
      "postDebugTask": "daprd: stop aasubservice (F5)",
      "program": "${workspaceFolder}/AASubService/bin/Debug/net8.0/AASubService.dll",
      "args": [],
      "cwd": "${workspaceFolder}/AASubService",
      "stopAtEntry": false,
      "console": "integratedTerminal",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "APP_PORT": "20008",
        "APP_ID": "aasubservice",
        "LEAFLETALARM_APP_ID": "integrationhost",
        "DAPR_HTTP_PORT": "3503",
        "DAPR_GRPC_PORT": "50031",
        "PUBSUB_NAME": "orderpubsub"
      }
    },
    {
      "name": "BlinkService (coreclr)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "prep: F5 blinkservice",
      "postDebugTask": "daprd: stop blinkservice (F5)",
      "program": "${workspaceFolder}/BlinkService/bin/Debug/net8.0/BlinkService.dll",
      "args": [],
      "cwd": "${workspaceFolder}/BlinkService",
      "stopAtEntry": false,
      "console": "integratedTerminal",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "HTTP_PORT": "20009",
        "APP_ID": "blinkservice",
        "DAPR_HTTP_PORT": "3504",
        "DAPR_GRPC_PORT": "50041",
        "PUBSUB_NAME": "orderpubsub",
        "MapDatabase__PgHost": "localhost",
        "MapDatabase__PgPort": "5432",
        "POSTGRES_USER": "keycloak",
        "POSTGRES_PASSWORD": "password",
        "DB_REALM_NAME": "myrealm"
      }
    },
    {
      "name": "Client: Vite dev (Chrome)",
      "type": "chrome",
      "request": "launch",
      "preLaunchTask": "client: dev (vite)",
      "url": "http://localhost:8002",
      "webRoot": "${workspaceFolder}/tree_alarm.client/src"
    }
  ],
  "compounds": [
    {
      "name": "Full: Backend + Client",
      "configurations": [
        "Backend: LeafletAlarms (coreclr)",
        "Client: Vite dev (Chrome)"
      ],
      "stopAll": true
    },
    {
      "name": "Backend + IntegrationHost",
      "configurations": [
        "Backend: LeafletAlarms (coreclr)",
        "IntegrationHost (coreclr)"
      ],
      "stopAll": true
    },
    {
      "name": "All services (F5)",
      "configurations": [
        "Backend: LeafletAlarms (coreclr)",
        "IntegrationHost (coreclr)",
        "GrpcTracksClient (coreclr)",
        "AASubService (coreclr)",
        "BlinkService (coreclr)",
        "Client: Vite dev (Chrome)"
      ],
      "stopAll": true
    }
  ]
}
